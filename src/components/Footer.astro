---
import { msg } from '../i18n/index';
const year = String(new Date().getFullYear());
---
<footer class="bg-surface border-t border-border mt-auto">
	<div class="mx-auto max-w-[1280px] px-4 py-8">
		<div class="flex flex-col md:flex-row items-center justify-between gap-4">
			<p class="text-sm text-muted">
				{msg('footer.rights', { year })}
			</p>
			<div class="flex gap-6 text-sm text-muted">
				<a href="#" class="hover:text-foreground transition-colors">{msg('footer.about')}</a>
				<a href="#" class="hover:text-foreground transition-colors">{msg('footer.contact')}</a>
				<a href="#" class="hover:text-foreground transition-colors">{msg('footer.terms')}</a>
			</div>
		</div>
	</div>
</footer>
