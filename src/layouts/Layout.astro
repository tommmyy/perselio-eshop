---
import '../styles/global.css';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer.astro';
import { getTopLevelCategories, getProducts, getSearchSuggestions } from '../lib/data';
import { htmlLang } from '../i18n/index';

interface Props {
	title?: string;
}

const { title = 'DemoShop' } = Astro.props;

const categories = getTopLevelCategories().map((c) => ({
	name: c.name,
	slug: c.slug,
	subcategories: c.subcategories,
}));

const autocompleteProducts = getProducts().map((p) => ({
	id: p.id,
	name: p.name,
	brand: p.brand,
	price: p.price,
	priceOld: p.priceOld ?? null,
	imageUrl: p.imageUrls?.[0] ?? '',
}));

const searchSuggestions = getSearchSuggestions();
---
<!doctype html>
<html lang={htmlLang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body class="min-h-screen flex flex-col">
		<Navbar client:load categories={categories} autocompleteProducts={autocompleteProducts} searchSuggestions={searchSuggestions} />
		<main class="flex-1">
			<slot />
		</main>
		<Footer />
	</body>
</html>
