---
import '../styles/global.css';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent';
import { getTopLevelCategories, getProducts, getSearchSuggestions } from '../lib/data';
import { htmlLang } from '../i18n/index';

interface Props {
	title?: string;
}

const { title = 'DemoShop' } = Astro.props;

const categories = getTopLevelCategories().map((c) => ({
	name: c.name,
	slug: c.slug,
	subcategories: c.subcategories,
}));

const autocompleteProducts = getProducts().map((p) => ({
	id: p.id,
	name: p.name,
	brand: p.brand,
	price: p.price,
	priceOld: p.priceOld ?? null,
	imageUrl: p.imageUrls?.[0] ?? '',
}));

const searchSuggestions = getSearchSuggestions();

const gtmContainer: string =
	(import.meta as any).env?.SHOP_GTM_CONTAINER ??
	(typeof process !== 'undefined' ? process.env.SHOP_GTM_CONTAINER : undefined) ??
	'';

---
<!doctype html>
<html lang={htmlLang}>
	<head>
		<!-- Google Consent Mode v2 — must run before any gtag/GTM scripts -->
		<script is:inline>
		window.dataLayer = window.dataLayer || [];
		function gtag(){dataLayer.push(arguments);}

		// Default: deny all until user interacts with cookie banner
		gtag('consent', 'default', {
			analytics_storage: 'denied',
			ad_storage: 'denied',
			ad_user_data: 'denied',
			ad_personalization: 'denied',
			wait_for_update: 500
		});

		// Restore consent from cookie if user already made a choice
		(function() {
			var match = document.cookie.split('; ').find(function(c) {
				return c.indexOf('cookie_consent=') === 0;
			});
			if (match) {
				try {
					var consent = JSON.parse(decodeURIComponent(match.split('=')[1]));
					gtag('consent', 'update', consent);
				} catch(e) {}
			}
		})();
		</script>
		<!-- End Google Consent Mode v2 -->

		<!-- Perselio -->
		<script src="https://static.perselio.com/versions/v3/interactions-prs.js"></script>
		<!-- End Perselio -->

		<script async src="https://www.googletagmanager.com/gtag/js?id=G-PX5BD6E4L2"></script>

		<!-- Google Tag Manager -->
		<script define:vars={{ gtmContainer }}>
		if (gtmContainer) {
			(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
			new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
			j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
			'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
			})(window,document,'script','dataLayer',gtmContainer);
		}
		</script>
		<!-- End Google Tag Manager -->

		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body class="min-h-screen flex flex-col">
		<!-- Google Tag Manager (noscript) -->
		<noscript><iframe src={`https://www.googletagmanager.com/ns.html?id=${gtmContainer}`}
		height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
		<!-- End Google Tag Manager (noscript) -->

		<Navbar client:load categories={categories} autocompleteProducts={autocompleteProducts} searchSuggestions={searchSuggestions} />
		<main class="flex-1">
			<slot />
		</main>
		<Footer />
		<CookieConsent client:load />
	</body>
</html>
