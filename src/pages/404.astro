---
import Layout from '../layouts/Layout.astro';
import { msg } from '../i18n/index';
---

<Layout title={msg('notFound.title')}>
	<div class="mx-auto max-w-[1280px] px-4 py-24 text-center">
		<h1 class="text-6xl font-bold text-primary mb-4">404</h1>
		<p class="text-xl text-muted mb-8">{msg('notFound.heading')}</p>
		<a
			href="/"
			class="inline-block px-6 py-3 bg-primary text-primary-foreground rounded-[9999px] font-semibold hover:opacity-90 transition-opacity"
		>
			{msg('notFound.backToHomepage')}
		</a>
	</div>
</Layout>
